{
  "name": "pi-tray-lite-extension",
  "version": "0.1.0",
  "description": "Pi extension for managing local forks and upstream changes.",
  "type": "module",
  "main": "./extension.ts",
  "exports": {
    ".": "./extension.ts",
    "./extension": "./extension.ts",
    "./protocol/handlers": "./protocol/handlers.ts",
    "./pi.protocol.json": "./pi.protocol.json"
  },
  "keywords": ["pi-package", "pi", "forks", "upstream", "tray"],
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@kyvernitria/pi-protocol-minimal": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@kyvernitria/pi-protocol-minimal": "file:../../pi-protocol/packages/pi-protocol-minimal",
    "@types/node": "^24.0.0",
    "typebox": "^1.1.34",
    "typescript": "^5.0.0"
  },
  "pi": {
    "extensions": ["./extension.ts"]
  }
}
